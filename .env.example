# Required for all Google ADK agents
GOOGLE_API_KEY=your_google_api_key_here

# GCP project / region (used by deploy_agent.py)
GCP_PROJECT_ID=osu-genesis-hub
GOOGLE_CLOUD_LOCATION=us-west1

# Optional: auto-sync deployed URL to GENESIS-AI-Hub registry after deploy
# HUB_URL   = base URL of your hub instance (no trailing slash)
# HUB_TOKEN = bearer token from hub login (Settings → Account → API Key, or copy
#             from browser localStorage: open DevTools → Application → Local Storage
#             → your hub URL → token)
HUB_URL=https://your-hub.run.app
HUB_TOKEN=your_hub_bearer_token_here
