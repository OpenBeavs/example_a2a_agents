# Required for all Google ADK agents
GOOGLE_API_KEY=your_google_api_key_here

# GCP project / region (used by deploy_agent.py)
GCP_PROJECT_ID=osu-genesis-hub
GOOGLE_CLOUD_LOCATION=us-west1

# Hub auto-sync — deploy_agent.py signs in automatically, no token copying needed
HUB_URL=https://your-hub.run.app
HUB_EMAIL=your@email.com
HUB_PASSWORD=yourpassword
